# ── Python ────────────────────────────────────────────────────
__pycache__/
*.py[cod]

# ── Build PyInstaller ─────────────────────────────────────────
build/
dist/
# NOTE : main_watcher.spec est versionné (nécessaire pour recompiler l'EXE)

# ── Exécutable compilé ────────────────────────────────────────
*.exe

# ── Logs & audit runtime ──────────────────────────────────────
workflow.log
workflow.log.*
workflow.json
audit_report.json

# ── Dossiers de travail temporaires ──────────────────────────
_tmp_work/
backups/

# ── Fichiers Excel (production + lock Office) ─────────────────
*.xlsx
*.xlsm
~$*.xlsx
~$*.xlsm

# ── PDFs (entrants, traités, erreurs, tests) ──────────────────
*.pdf

# ── Hashes traités (état runtime) ────────────────────────────
processed_hashes.txt

# ── Dossiers pipeline (contenu, pas les dossiers eux-mêmes) ──
Entrant/*
Traite/*
Erreur/*
1_Entrant_Deposer_PDF/*
2_Traite_Succes/*
3_Erreur_A_Verifier/*
References/*
!Entrant/.gitkeep
!Traite/.gitkeep
!Erreur/.gitkeep

# ── Environnements virtuels ───────────────────────────────────
.venv/
venv/
env/

# ── OS ────────────────────────────────────────────────────────
Thumbs.db
desktop.ini
